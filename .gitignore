data/
*.parquet

# 前端依赖
frontend/node_modules/

# 数据库文件
*.db
*.db-shm
*.db-wal

# 备份文件
*.bak
*.bak2
*.bak3

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 日志
*.log

# 运行时文件
star-query-history.db
query_history.json.bak
*.json.bak

# 内部记录
memory/
regression_reports/

# 操作系统
.DS_Store
Thumbs.db

